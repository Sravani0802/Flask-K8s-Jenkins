pipeline{
  agent any
  stage {

    stage('Webhook Test') {
      steps {
        echo "GitHub webhook triggered successfully!"
      }
    }

    stage('Clone Repo') {
    steps {
      git branch: 'main',
          url: 'https://github.com/Sravani0802/Flask-k8s-jenkins.git'
    }
    }

    stage('Build Docker Image') {
      steps {
        sh 'docker build -t flask-calculator:latest .'
      }
    }

    stage('Deploy to Kubernetes') {
      steps {
        sh 'kubectl apply -f k8s/'
      }
    }
  }
}