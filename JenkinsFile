pipeline {
    agent any

    environment {
        AWS_REGION = 'ap-south-1'
        ECR_REPO  = '138383657739.dkr.ecr.ap-south-1.amazonaws.com/flask-cal'
        IMAGE_TAG = "${env.BUILD_NUMBER}"
    }

    stages {
        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/Sravani0802/Flask-K8s-Jenkins.git'
            }
        }

        stage('Build Docker Image') {
            steps {
              script{
                docker.build("${ECR_REPO}:${IMAGE_TAG}")
              }
            }
        }


        stage('Login to ECR') {
            steps {
                script {
                    sh """
                    aws ecr get-login-password --region ${AWS_REGION} | \
                    docker login --username AWS --password-stdin ${ECR_REPO}
                    """
                }
            }
        }

        stage('Push to ECR') {
            steps {
              script {
                bat "docker push ${ECR_REPO}:${IMAGE_TAG}"
              }
            }
        }

        stage('Deploy to EKS') {
            steps {
              script {
              // Configure kubeconfig
                bat "aws eks update-kubeconfig --region ${AWS_REGION} --name flask-ecr"

              // Replace image in deployment.yaml dynamically
                bat "sed -i 's|image:.*|image: ${ECR_REPO}:${IMAGE_TAG}|' k8s//deployment.yaml"

              // Apply Kubernetes manifests
                bat "kubectl apply -f k8s/deployment.yaml"
                bat "kubectl apply -f k8s/service.yaml"
              }
            }
        }
    }
}
